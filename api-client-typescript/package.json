{
  "name": "@aixigo-sample-projects/api-client-typescript",
  "version": "0.1.0",
  "description": "A sample API client",
  "author": "aixigo",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+ssh://git@gitlab.com/aixigoAG/community-portal/sample-projects/api-clients.git"
  },
  "type": "module",
  "main": "src/main.ts",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "openapi-typescript ../spec.openapi.yaml -o src/schema.d.ts && tsc",
    "lint:code": "eslint --ext .ts --ignore-path .gitignore --ignore-pattern 'vendor/*' .",
    "lint:prettier": "prettier --check src",
    "lint": "npm run lint:code && npm run lint:prettier",
    "lint:fix": "prettier --write --list-different src && npm run lint:code --fix src"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^18.19.33",
    "@typescript-eslint/parser": "^7.4.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "openapi-typescript": "^6.7.6",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "openapi-fetch": "^0.9.7"
  }
}
